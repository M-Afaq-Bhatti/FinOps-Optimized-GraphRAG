# ── Required ──────────────────────────────────────────────────────────────────
# Get your free key from https://aistudio.google.com
GEMINI_API_KEY= Your_GOOGLE_API_KEY

# ── Optional ──────────────────────────────────────────────────────────────────
# Where LightRAG stores its knowledge graph and vector indexes
RAG_STORAGE_DIR=rag_storage

# Where uploaded documents are saved
DATA_DIR=data

# Unset GOOGLE_API_KEY if you have it set system-wide (it conflicts)
# Run: unset GOOGLE_API_KEY
